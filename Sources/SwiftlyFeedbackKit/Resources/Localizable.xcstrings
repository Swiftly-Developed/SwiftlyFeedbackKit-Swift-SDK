    "feedback.list.empty.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Be the first to share your thoughts!"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¡Sé el primero en compartir tus ideas!"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Soyez le premier à partager vos idées !"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sei der Erste, der seine Gedanken teilt!"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最初にあなたの意見を共有しましょう！"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "成为第一个分享想法的人！"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Seja o primeiro a compartilhar suas ideias!"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "첨 번째로 의견을 나눠보세요!"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sii il primo a condividere le tue idee!"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "كن أول من يشارك أفكاره!"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Будьте первым, кто поделится своими мыслями!"
          }
        }
      }
    },
