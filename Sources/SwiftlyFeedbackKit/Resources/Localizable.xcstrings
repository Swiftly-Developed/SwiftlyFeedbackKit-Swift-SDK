    "error.invalidApiKey.message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The feedback system is not configured correctly. Please contact the app developers for assistance."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El sistema de comentarios no está configurado correctamente. Contacta a los desarrolladores de la app para obtener ayuda."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le système de retours n'est pas configuré correctement. Veuillez contacter les développeurs de l'application pour obtenir de l'aide."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Feedback-System ist nicht korrekt konfiguriert. Bitte kontaktieren Sie die App-Entwickler für Hilfe."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "フィードバックシステムが正しく設定されていません。アプリ開発者にお問い合わせください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "反馈系统配置不正确。请联系应用开发者获取帮助。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O sistema de feedback não está configurado corretamente. Entre em contato com os desenvolvedores do app para obter ajuda."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "피드백 시스템이 올바르게 구성되지 않았습니다. 앱 개발자에게 문의해 주세요."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il sistema di feedback non è configurato correttamente. Contatta gli sviluppatori dell'app per assistenza."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "نظام الملاحظات غير مهيأ بشكل صحيح. يرجى التواصل مع مطوري التطبيق للمساعدة."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Система отзывов настроена неправильно. Свяжитесь с разработчиками приложения для помощи."
          }
        }
      }
    },
