    "feedback.submission.disabled.message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Feedback submission is not available. You can still vote for existing feedback."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El envío de comentarios no está disponible. Aún puedes votar por comentarios existentes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La soumission de retours n'est pas disponible. Vous pouvez toujours voter pour les retours existants."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Feedback-Einreichung ist nicht verfügbar. Sie können weiterhin für vorhandenes Feedback abstimmen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "フィードバックの送信は利用できません。既存のフィードバックには投票できます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "反馈提交不可用。您仍可以为现有反馈投票。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O envio de feedback não está disponível. Você ainda pode votar em feedbacks existentes."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "피드백 제출이 불가합니다. 기존 피드백에 투표할 수 있습니다."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'invio di feedback non è disponibile. Puoi ancora votare per i feedback esistenti."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إرسال الملاحظات غير متاح. لا يزال بإمكانك التصويت للملاحظات الموجودة."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отправка отзывов недоступна. Вы по-прежнему можете голосовать за существующие отзывы."
          }
        }
      }
    },
