    "error.feedbackLimit.message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This project has reached its feedback limit. Contact the project owner to upgrade."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este proyecto ha alcanzado su límite de comentarios. Contacta al propietario del proyecto para actualizar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce projet a atteint sa limite de retours. Contactez le propriétaire du projet pour mettre à niveau."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieses Projekt hat sein Feedback-Limit erreicht. Kontaktieren Sie den Projektbesitzer für ein Upgrade."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このプロジェクトはフィードバック上限に達しました。プロジェクトオーナーにアップグレードをお問い合わせください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此项目已达到反馈上限。请联系项目所有者进行升级。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este projeto atingiu seu limite de feedback. Entre em contato com o proprietário do projeto para fazer upgrade."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 프로젝트의 피드백 한도에 도달했습니다. 프로젝트 소유자에게 업그레이드를 문의하세요."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo progetto ha raggiunto il limite di feedback. Contatta il proprietario del progetto per l'upgrade."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "وصل هذا المشروع إلى حد الملاحظات. تواصل مع مالك المشروع للترقية."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Этот проект достиг лимита отзывов. Свяжитесь с владельцем проекта для обновления."
          }
        }
      }
    },
